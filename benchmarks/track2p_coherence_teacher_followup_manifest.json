{
  "defaults": {
    "data": "<DATA_ROOT>",
    "reference": "<REFERENCE_ROOT>",
    "reference_kind": "manual-gt",
    "input_format": "suite2p",
    "plane_name": "plane0",
    "include_behavior": false,
    "threshold_method": "min",
    "transform_type": "affine",
    "iou_distance_threshold": 12,
    "cell_probability_threshold": 0.5,
    "split_risk_threshold": 1.5,
    "min_side_observations": 2
  },
  "runs": [
    {
      "name": "component_cleanup",
      "runner": "track2p-policy-component-audit",
      "apply_splits": true,
      "output": "component_cleanup.csv"
    },
    {
      "name": "coherence_suffix_stitch",
      "runner": "track2p-policy-coherence-suffix-stitch",
      "suffix_path_length": 2,
      "min_cell_probability": 0.8,
      "min_area_ratio": 0.8,
      "max_centroid_distance": 6.0,
      "min_shifted_iou": 0.3,
      "min_motion_consistency": 0.5,
      "min_shape_consistency": 0.82,
      "max_stitches_per_subject": 1,
      "output": "coherence_suffix_stitch.csv"
    },
    {
      "name": "coherence_suffix_teacher_rescue",
      "runner": "track2p-policy-coherence-suffix-teacher-rescue",
      "suffix_path_length": 2,
      "min_cell_probability": 0.8,
      "min_area_ratio": 0.8,
      "max_centroid_distance": 6.0,
      "min_shifted_iou": 0.3,
      "min_motion_consistency": 0.5,
      "min_shape_consistency": 0.82,
      "max_stitches_per_subject": 1,
      "teacher_edge_order": "dynamic-confidence",
      "teacher_action_filter": "target-extension",
      "teacher_feature_preset": "track2p-fn-rescue",
      "max_applied_teacher_edits": 2,
      "output": "coherence_suffix_teacher_rescue.csv"
    }
  ],
  "comparisons": [
    {
      "name": "coherence_teacher_followup_comparison",
      "inputs": {
        "ComponentCleanup": "component_cleanup",
        "CoherenceSuffixStitch": "coherence_suffix_stitch",
        "CoherenceSuffixTeacherRescue": "coherence_suffix_teacher_rescue"
      },
      "output": "coherence_teacher_followup_comparison.md",
      "format": "markdown",
      "highlight_best": true
    },
    {
      "name": "coherence_teacher_followup_comparison_csv",
      "inputs": {
        "ComponentCleanup": "component_cleanup",
        "CoherenceSuffixStitch": "coherence_suffix_stitch",
        "CoherenceSuffixTeacherRescue": "coherence_suffix_teacher_rescue"
      },
      "output": "coherence_teacher_followup_comparison.csv",
      "format": "csv"
    }
  ]
}
