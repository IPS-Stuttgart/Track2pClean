{
  "defaults": {
    "data": "<DATA_ROOT>",
    "reference": "<REFERENCE_ROOT>",
    "reference_kind": "manual-gt",
    "input_format": "suite2p",
    "format": "csv",
    "progress": true
  },
  "runs": [
    {
      "name": "PyRecEstCellGatedMHT",
      "runner": "track2p-policy-pyrecest-residual-mht-cleanup",
      "output": "<OUTPUT_ROOT>/pyrecest_cellgated_mht.csv",
      "transform_type": "affine",
      "threshold_method": "min",
      "iou_distance_threshold": 12.0,
      "cell_probability_threshold": 0.5,
      "split_risk_threshold": 1.5,
      "min_side_observations": 2,
      "suffix_path_length": 2,
      "min_cell_probability": 0.8,
      "min_area_ratio": 0.8,
      "max_centroid_distance": 6.0,
      "min_shifted_iou": 0.3,
      "min_motion_consistency": 0.5,
      "min_shape_consistency": 0.82,
      "max_stitches_per_subject": 1,
      "min_growth_residual_mahalanobis": 20.0,
      "min_growth_residual": 2.5,
      "min_veto_registered_iou": 0.45,
      "max_veto_registered_iou": 0.60,
      "min_veto_shifted_iou": 0.60,
      "max_veto_shifted_iou": 0.80,
      "min_veto_cell_probability": 0.50,
      "max_veto_min_cell_probability": null,
      "max_veto_local_neighbor_distortion": null,
      "max_veto_row_rank": 1,
      "max_veto_column_rank": 1,
      "require_veto_not_suffix_edge": true,
      "require_veto_terminal_edge": true,
      "require_veto_last_session_edge": true,
      "require_veto_complete_component": true,
      "max_vetoes_per_subject": 2,
      "mht_candidate_top_k": 8,
      "mht_max_edits_per_subject": 2,
      "mht_max_hypotheses": 32,
      "mht_edit_penalty": 0.25,
      "mht_score_threshold": 1.0,
      "mht_include_high_overlap_low_motion_candidates": true,
      "mht_high_overlap_min_registered_iou": 0.83,
      "mht_high_overlap_max_growth_residual": 0.65,
      "mht_high_overlap_min_growth_residual_mahalanobis": 1.0,
      "mht_high_overlap_min_cell_probability": 0.75,
      "mht_high_overlap_score_bonus": 2.0
    },
    {
      "name": "CellGatedDeterministicGate",
      "runner": "track2p-policy-pyrecest-residual-mht-cleanup",
      "output": "<OUTPUT_ROOT>/cellgated_deterministic_gate.csv",
      "transform_type": "affine",
      "threshold_method": "min",
      "iou_distance_threshold": 12.0,
      "cell_probability_threshold": 0.5,
      "split_risk_threshold": 1.5,
      "min_side_observations": 2,
      "suffix_path_length": 2,
      "min_cell_probability": 0.8,
      "min_area_ratio": 0.8,
      "max_centroid_distance": 6.0,
      "min_shifted_iou": 0.3,
      "min_motion_consistency": 0.5,
      "min_shape_consistency": 0.82,
      "max_stitches_per_subject": 1,
      "min_growth_residual_mahalanobis": 20.0,
      "min_growth_residual": 2.5,
      "min_veto_registered_iou": 0.45,
      "max_veto_registered_iou": 0.60,
      "min_veto_shifted_iou": 0.60,
      "max_veto_shifted_iou": 0.80,
      "min_veto_cell_probability": 0.50,
      "max_veto_min_cell_probability": null,
      "max_veto_local_neighbor_distortion": null,
      "max_veto_row_rank": 1,
      "max_veto_column_rank": 1,
      "require_veto_not_suffix_edge": true,
      "require_veto_terminal_edge": true,
      "require_veto_last_session_edge": true,
      "require_veto_complete_component": true,
      "max_vetoes_per_subject": 2,
      "mht_candidate_top_k": 8,
      "mht_max_edits_per_subject": 2,
      "mht_max_hypotheses": 32,
      "mht_edit_penalty": 0.25,
      "mht_score_threshold": 1.0,
      "mht_selection_mode": "deterministic-gating",
      "mht_include_high_overlap_low_motion_candidates": true,
      "mht_high_overlap_min_registered_iou": 0.83,
      "mht_high_overlap_max_growth_residual": 0.65,
      "mht_high_overlap_min_growth_residual_mahalanobis": 1.0,
      "mht_high_overlap_min_cell_probability": 0.75,
      "mht_high_overlap_score_bonus": 2.0
    }
  ],
  "comparisons": [
    {
      "name": "pyrecest-mht-vs-deterministic-gating-ablation-md",
      "inputs": {
        "PyRecEstCellGatedMHT": "PyRecEstCellGatedMHT",
        "CellGatedDeterministicGate": "CellGatedDeterministicGate"
      },
      "output": "<OUTPUT_ROOT>/pyrecest_mht_vs_deterministic_gating_ablation.md",
      "format": "markdown",
      "highlight_best": true
    },
    {
      "name": "pyrecest-mht-vs-deterministic-gating-ablation-csv",
      "inputs": {
        "PyRecEstCellGatedMHT": "PyRecEstCellGatedMHT",
        "CellGatedDeterministicGate": "CellGatedDeterministicGate"
      },
      "output": "<OUTPUT_ROOT>/pyrecest_mht_vs_deterministic_gating_ablation.csv",
      "format": "csv",
      "highlight_best": true
    }
  ]
}
