{
  "defaults": {
    "data": "/home/florianpfaff/codex-runs/BayesCaTrack/results/policy_dp/data_lightweight",
    "reference": "/home/florianpfaff/codex-runs/BayesCaTrack/results/policy_dp/data_lightweight",
    "reference_kind": "manual-gt",
    "input_format": "suite2p",
    "threshold_method": "min",
    "transform_type": "affine",
    "iou_distance_threshold": 12,
    "cell_probability_threshold": 0.5
  },
  "runs": [
    {
      "name": "Track2p",
      "runner": "track2p",
      "method": "track2p-baseline",
      "output": "full_mht_prior_veto/track2p.csv",
      "format": "csv"
    },
    {
      "name": "FullMHTPrior2",
      "runner": "track2p-full-mht",
      "output": "full_mht_prior_veto/full_mht_prior2.csv",
      "format": "csv",
      "seed_source": "reference",
      "beam_width": 8,
      "scan_hypotheses": 8,
      "edge_top_k": 4,
      "identity_diverse_beam": true,
      "miss_cost": 2.0,
      "full_mht_max_gap": 1,
      "gap_reactivation_cost": 1.0,
      "min_output_observations": 1,
      "min_edge_score": 0.25,
      "track2p_prior_weight": 12.0,
      "track2p_non_prior_penalty": 2.0,
      "track2p_prior_switch_penalty": 8.0,
      "track2p_no_prior_successor_penalty": 8.0,
      "track2p_prior_miss_penalty": 4.0
    },
    {
      "name": "FullMHTGreedyPrior2",
      "runner": "track2p-full-mht",
      "output": "full_mht_prior_veto/full_mht_greedy_prior2.csv",
      "format": "csv",
      "seed_source": "reference",
      "beam_width": 1,
      "scan_hypotheses": 8,
      "edge_top_k": 4,
      "identity_diverse_beam": false,
      "miss_cost": 2.0,
      "full_mht_max_gap": 1,
      "gap_reactivation_cost": 1.0,
      "min_output_observations": 1,
      "min_edge_score": 0.25,
      "track2p_prior_weight": 12.0,
      "track2p_non_prior_penalty": 2.0,
      "track2p_prior_switch_penalty": 8.0,
      "track2p_no_prior_successor_penalty": 8.0,
      "track2p_prior_miss_penalty": 4.0
    },
    {
      "name": "FullMHTPriorVetoScaled",
      "runner": "track2p-full-mht",
      "output": "full_mht_prior_veto/full_mht_prior_veto_scaled.csv",
      "format": "csv",
      "seed_source": "reference",
      "beam_width": 8,
      "scan_hypotheses": 8,
      "edge_top_k": 4,
      "identity_diverse_beam": true,
      "miss_cost": 2.0,
      "full_mht_max_gap": 1,
      "gap_reactivation_cost": 1.0,
      "min_output_observations": 1,
      "min_edge_score": 0.25,
      "track2p_prior_weight": 12.0,
      "track2p_non_prior_penalty": 2.0,
      "track2p_prior_switch_penalty": 8.0,
      "track2p_no_prior_successor_penalty": 8.0,
      "track2p_prior_miss_penalty": 4.0,
      "track2p_prior_veto_penalty": 20.0,
      "track2p_prior_veto_min_growth_residual_mahalanobis": 2.5,
      "track2p_prior_veto_min_growth_residual": 2.5,
      "track2p_prior_veto_min_registered_iou": 0.35,
      "track2p_prior_veto_max_registered_iou": 0.40,
      "track2p_prior_veto_min_shifted_iou": 0.60,
      "track2p_prior_veto_max_shifted_iou": 0.80,
      "track2p_prior_veto_min_cell_probability": 0.50,
      "track2p_prior_veto_max_min_cell_probability": 0.65,
      "track2p_prior_veto_max_row_rank": 1,
      "track2p_prior_veto_max_column_rank": 1,
      "track2p_prior_veto_require_terminal_edge": true,
      "track2p_prior_veto_require_last_session_edge": true,
      "track2p_prior_veto_require_complete_component": true
    },
    {
      "name": "FullMHTPriorSurvival",
      "runner": "track2p-full-mht",
      "output": "full_mht_prior_veto/full_mht_prior_survival.csv",
      "format": "csv",
      "seed_source": "reference",
      "beam_width": 8,
      "scan_hypotheses": 8,
      "edge_top_k": 4,
      "identity_diverse_beam": true,
      "miss_cost": 2.0,
      "full_mht_max_gap": 1,
      "gap_reactivation_cost": 1.0,
      "min_output_observations": 1,
      "min_edge_score": 0.25,
      "track2p_prior_weight": 12.0,
      "track2p_non_prior_penalty": 2.0,
      "track2p_prior_switch_penalty": 8.0,
      "track2p_no_prior_successor_penalty": 8.0,
      "track2p_prior_miss_penalty": 4.0,
      "track2p_prior_survival_weight": 1.0,
      "track2p_prior_survival_min_examples_per_class": 2,
      "track2p_prior_survival_score_clip": 8.0
    }
  ],
  "comparisons": [
    {
      "name": "full-mht-prior-veto-comparison-md",
      "inputs": {
        "Track2p": "Track2p",
        "FullMHTPrior2": "FullMHTPrior2",
        "FullMHTGreedyPrior2": "FullMHTGreedyPrior2",
        "FullMHTPriorVetoScaled": "FullMHTPriorVetoScaled",
        "FullMHTPriorSurvival": "FullMHTPriorSurvival"
      },
      "output": "full_mht_prior_veto/full_mht_prior_veto_comparison.md",
      "format": "markdown",
      "highlight_best": true
    },
    {
      "name": "full-mht-prior-veto-comparison-csv",
      "inputs": {
        "Track2p": "Track2p",
        "FullMHTPrior2": "FullMHTPrior2",
        "FullMHTGreedyPrior2": "FullMHTGreedyPrior2",
        "FullMHTPriorVetoScaled": "FullMHTPriorVetoScaled",
        "FullMHTPriorSurvival": "FullMHTPriorSurvival"
      },
      "output": "full_mht_prior_veto/full_mht_prior_veto_comparison.csv",
      "format": "csv",
      "highlight_best": true
    }
  ]
}
