  "comparisons": [
    {
      "name": "pyrecest-cellgated-mht-comparison-md",
      "inputs": {
        "Track2p": "Track2p",
        "CoherenceSuffixGrowthVeto": "CoherenceSuffixGrowthVeto",
        "PyRecEstResidualMHT": "PyRecEstResidualMHT",
        "PyRecEstDualPocketMHT": "PyRecEstDualPocketMHT",
